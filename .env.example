OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Optional second provider used by the "Today" backlog triage (the
# whole-feed-backlog drain scores survivors with a stronger model). Point it
# at any OpenAI-compatible endpoint. Leave blank to skip backlog triage.
CUSTOM_BASE_URL=https://your-provider.example/v1
CUSTOM_API_KEY=your_custom_api_key_here

# OpenRouter is also supported as an api_key_env for the classify-llm CLI.
# OPENROUTER_API_KEY=your_openrouter_key_here

SUMMARY_TIMEOUT_SECONDS=900
TRIAGE_JOB_CONCURRENCY=4
PDF_ROOT=/Users/your-user/Zotero/storage
ZOTERO_DATA_DIR=/Users/your-user/Zotero
ONPREM_PATH=/Users/your-user/code/from GH/onprem
ZOTERO_SUMMARIZER_HOME=/Users/your-user/code/personal/zotero-summarizer
APP_LOG_LEVEL=INFO
APP_LOG_FILE=server.log
