OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Optional second provider used by the "Today" backlog triage (the
# whole-feed-backlog drain scores survivors with a stronger model). Point it
# at any OpenAI-compatible endpoint. Leave blank to skip backlog triage.
CUSTOM_BASE_URL=https://your-provider.example/v1
CUSTOM_API_KEY=your_custom_api_key_here

# OpenRouter is also supported as an api_key_env for the classify-llm CLI.
# OPENROUTER_API_KEY=your_openrouter_key_here

# Local MLX models (Apple Silicon) via `mlx_lm.server` — an OpenAI-compatible
# endpoint. Start it with thinking disabled (server flag is --chat-template-args;
# note `mlx_lm.generate` uses --chat-template-config instead):
#   mlx_lm.server --model ~/models/mlx/<your-model> --port 8080 \
#                 --chat-template-args '{"enable_thinking": false}'
# In the provider profile, set `model:` to the SAME string you passed to --model
# (the full path), or "default_model" — mlx_lm.server treats any other model name
# as a HuggingFace repo id and 404s. mlx_lm.server needs no API key, but providers
# require an api_key_env, so set a dummy value here and reference MLX_API_KEY.
# MLX_API_KEY=local

SUMMARY_TIMEOUT_SECONDS=900
TRIAGE_JOB_CONCURRENCY=4
PDF_ROOT=/Users/your-user/Zotero/storage
ZOTERO_DATA_DIR=/Users/your-user/Zotero
ONPREM_PATH=/Users/your-user/code/from GH/onprem
ZOTERO_SUMMARIZER_HOME=/Users/your-user/code/personal/zotero-summarizer
APP_LOG_LEVEL=INFO
APP_LOG_FILE=server.log

# Offline / air-gapped use: set ZS_OFFLINE=1 to load the ML models cache-only
# (no HuggingFace hub check → no startup timeout when disconnected). Pre-cache the
# models once while online with `zotero-summarizer prefetch-models`. For fully-offline
# LLM features, point the provider base_url at a LOCAL endpoint (Ollama/vLLM/LM Studio).
# ZS_OFFLINE=1
